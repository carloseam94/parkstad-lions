---
const { locale, t } = Astro.props;

const registrationI18n = {
  subject: t("registration.title"),
  sending: t("registration.sending"),
  success: t("registration.success"),
  error: t("registration.error"),
  givenName: t("registration.givenName"),
  preferredName: t("registration.preferredName"),
  lastName: t("registration.lastName"),
  birthdate: t("registration.birthdate"),
  gender: t("registration.gender"),
  male: t("registration.male"),
  female: t("registration.female"),
  email: t("registration.email"),
  address: t("registration.address"),
  phone: t("registration.phone"),
};
---

<button
  id="openRegistrationModal"
  class="inline-block rounded border border-blue-600 bg-blue-600 px-5 py-3 font-medium text-white shadow-sm transition-colors hover:bg-blue-700 cursor-pointer"
>
  {t("registration.openButton")}
</button>

<div
  id="registrationModal"
  class="fixed inset-0 z-50 hidden items-center justify-center"
  style="background-color: rgba(0, 0, 0, 0.5);"
>
  <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto border border-gray-200">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-2xl font-bold text-gray-900">
          {t("registration.title")}
        </h2>
        <button
          id="closeRegistrationModal"
          class="text-gray-400 hover:text-gray-600 cursor-pointer"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <form id="registrationForm" class="space-y-4">
        <div>
          <label for="givenName" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.givenName")} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="givenName"
            name="givenName"
            required
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div>
          <label for="lastName" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.lastName")} <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div>
          <label for="preferredName" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.preferredName")}
          </label>
          <input
            type="text"
            id="preferredName"
            name="preferredName"
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div>
          <label for="birthdate" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.birthdate")} <span class="text-red-500">*</span>
          </label>
          <input
            type="date"
            id="birthdate"
            name="birthdate"
            required
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div>
          <label class="block text-left text-sm font-medium text-gray-700 mb-2">
            {t("registration.gender")}
          </label>
          <div class="flex gap-4">
            <label class="flex items-center">
              <input
                type="radio"
                name="gender"
                value="male"
                class="w-4 h-4 text-blue-600 focus:ring-blue-600"
              />
              <span class="ml-2 text-sm text-gray-700">{t("registration.male")}</span>
            </label>
            <label class="flex items-center">
              <input
                type="radio"
                name="gender"
                value="female"
                class="w-4 h-4 text-blue-600 focus:ring-blue-600"
              />
              <span class="ml-2 text-sm text-gray-700">{t("registration.female")}</span>
            </label>
          </div>
        </div>

        <div>
          <label for="email" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.email")} <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div>
          <label for="address" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.address")}
          </label>
          <input
            type="text"
            id="address"
            name="address"
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div>
          <label for="phone" class="block text-left text-sm font-medium text-gray-700 mb-1">
            {t("registration.phone")}
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
          />
        </div>

        <div class="flex gap-3 pt-4">
          <button
            type="submit"
            class="flex-1 rounded border border-blue-600 bg-blue-600 px-5 py-2.5 font-medium text-white shadow-sm transition-colors hover:bg-blue-700 cursor-pointer"
          >
            {t("registration.submit")}
          </button>
          <button
            type="button"
            id="cancelRegistration"
            class="flex-1 rounded border border-gray-300 bg-white px-5 py-2.5 font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors cursor-pointer"
          >
            {t("registration.cancel")}
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script type="application/json" id="registrationI18n" set:html={JSON.stringify(registrationI18n)}></script>

<script>
  const modal = document.getElementById('registrationModal');
  const openBtn = document.getElementById('openRegistrationModal');
  const openBtnBanner = document.getElementById('openRegistrationModalBanner');
  const closeBtn = document.getElementById('closeRegistrationModal');
  const cancelBtn = document.getElementById('cancelRegistration');
  const form = document.getElementById('registrationForm') as HTMLFormElement;
  const i18nNode = document.getElementById('registrationI18n');
  const translations = i18nNode?.textContent ? JSON.parse(i18nNode.textContent) : {};

  function openModal() {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  }

  function closeModal() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    form?.reset();
  }

  openBtn?.addEventListener('click', openModal);
  openBtnBanner?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);

  // Close modal when clicking outside
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const givenName = formData.get('givenName') as string;
    const preferredName = formData.get('preferredName') as string;
    const lastName = formData.get('lastName') as string;
    const birthdate = formData.get('birthdate') as string;
    const gender = formData.get('gender') as string;
    const email = formData.get('email') as string;
    const address = formData.get('address') as string;
    const phone = formData.get('phone') as string;

    const genderLabel = gender === 'male' ? translations.male : 
                       gender === 'female' ? translations.female : '';

    // Create email body
    let body = `${translations.givenName}: ${givenName}\n`;
    if (preferredName) body += `${translations.preferredName}: ${preferredName}\n`;
    body += `${translations.lastName}: ${lastName}\n`;
    body += `${translations.birthdate}: ${birthdate}\n`;
    if (gender) body += `${translations.gender}: ${genderLabel}\n`;
    body += `${translations.email}: ${email}\n`;
    if (address) body += `${translations.address}: ${address}\n`;
    if (phone) body += `${translations.phone}: ${phone}\n`;

    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const defaultSubmitText = submitButton?.textContent ?? '';

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = translations.sending;
    }

    try {
      const response = await fetch('/api/send-email', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          subject: translations.subject,
          text: body,
          replyTo: email,
        }),
      });

      if (!response.ok) {
        throw new Error('Request failed');
      }

      alert(translations.success);
      closeModal();
    } catch (error) {
      console.error('Failed to send registration email', error);
      alert(translations.error);
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = defaultSubmitText;
      }
    }
  });
</script>
