---
const {
  t,
  includeModal = false,
  buttonClass = "inline-block rounded border border-blue-600 bg-blue-600 px-5 py-3 font-medium text-white shadow-sm transition-colors hover:bg-blue-700 cursor-pointer",
  buttonId,
} = Astro.props;

const contactModalI18n = {
  subject: t("contactModal.subject"),
  sending: t("contactModal.sending"),
  success: t("contactModal.success"),
  error: t("contactModal.error"),
  question: t("contactModal.question"),
  contact: t("contactModal.contact"),
};
---

<button
  id={buttonId}
  type="button"
  class={buttonClass}
  data-open-ask-us-anything
>
  {t("contactModal.openButton")}
</button>

{includeModal && (
  <>
    <div
      id="contactModal"
      class="fixed inset-0 z-50 hidden items-center justify-center"
      style="background-color: rgba(0, 0, 0, 0.5);"
    >
      <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 max-h-[90vh] overflow-y-auto border border-gray-200">
        <div class="p-6">
          <div class="flex justify-between items-center mb-4">
            <h2 class="text-2xl font-bold text-gray-900">
              {t("contactModal.title")}
            </h2>
            <button
              id="closeContactModal"
              class="text-gray-400 hover:text-gray-600 cursor-pointer"
              type="button"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>

          <form id="contactModalForm" class="space-y-4">
            <div>
              <label for="question" class="block text-left text-sm font-medium text-gray-700 mb-1">
                {t("contactModal.question")} <span class="text-red-500">*</span>
              </label>
              <textarea
                id="question"
                name="question"
                required
                rows="5"
                class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
              ></textarea>
            </div>

            <div>
              <label for="contact" class="block text-left text-sm font-medium text-gray-700 mb-1">
                {t("contactModal.contact")} <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="contact"
                name="contact"
                required
                placeholder={t("contactModal.contactPlaceholder")}
                class="w-full rounded-lg border border-gray-300 p-2.5 text-sm focus:ring-blue-600 focus:border-blue-600"
              />
            </div>

            <div class="flex gap-3 pt-4">
              <button
                type="submit"
                class="flex-1 rounded border border-blue-600 bg-blue-600 px-5 py-2.5 font-medium text-white shadow-sm transition-colors hover:bg-blue-700 cursor-pointer"
              >
                {t("contactModal.submit")}
              </button>
              <button
                type="button"
                id="cancelContactModal"
                class="flex-1 rounded border border-gray-300 bg-white px-5 py-2.5 font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors cursor-pointer"
              >
                {t("contactModal.cancel")}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script type="application/json" id="contactModalI18n" set:html={JSON.stringify(contactModalI18n)}></script>

    <script>
      const contactModal = document.getElementById('contactModal');
      const openContactModalButtons = document.querySelectorAll('[data-open-ask-us-anything]');
      const closeContactModalButton = document.getElementById('closeContactModal');
      const cancelContactModalButton = document.getElementById('cancelContactModal');
      const contactModalForm = document.getElementById('contactModalForm') as HTMLFormElement;
      const contactModalI18nNode = document.getElementById('contactModalI18n');
      const contactTranslations = contactModalI18nNode?.textContent ? JSON.parse(contactModalI18nNode.textContent) : {};

      function openContactModal() {
        contactModal?.classList.remove('hidden');
        contactModal?.classList.add('flex');
      }

      function closeContactModal() {
        contactModal?.classList.add('hidden');
        contactModal?.classList.remove('flex');
        contactModalForm?.reset();
      }

      openContactModalButtons.forEach((button) => {
        button.addEventListener('click', openContactModal);
      });
      closeContactModalButton?.addEventListener('click', closeContactModal);
      cancelContactModalButton?.addEventListener('click', closeContactModal);

      contactModal?.addEventListener('click', (e) => {
        if (e.target === contactModal) {
          closeContactModal();
        }
      });

      contactModalForm?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(contactModalForm);
        const question = (formData.get('question') as string)?.trim();
        const contact = (formData.get('contact') as string)?.trim();
        const isEmailContact = contact.includes('@');

        let text = `${contactTranslations.question}: ${question}\n`;
        text += `${contactTranslations.contact}: ${contact}`;

        const submitButton = contactModalForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        const defaultSubmitText = submitButton?.textContent ?? '';

        if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = contactTranslations.sending;
        }

        try {
          const payload = {
            subject: contactTranslations.subject,
            text,
            ...(isEmailContact ? { replyTo: contact } : {}),
          };

          const response = await fetch('/api/send-email', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error('Request failed');
          }

          alert(contactTranslations.success);
          closeContactModal();
        } catch (error) {
          console.error('Failed to send contact question', error);
          alert(contactTranslations.error);
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.textContent = defaultSubmitText;
          }
        }
      });
    </script>
  </>
)}
