---
const { t } = Astro.props;

const sponsors = [
  {
    name: "Strada B.V.",
    image: "/images/sponsors/strada-bv.png",
  },
  {
    name: "Plus",
    image: "/images/sponsors/plus.png",
  },
  {
    name: "Mosae Sports",
    image: "/images/sponsors/mosae-sports.png",
  },
  {
    name: "Strada B.V.",
    image: "/images/sponsors/strada-bv.png",
  },
  {
    name: "Plus",
    image: "/images/sponsors/plus.png",
  },
  {
    name: "Mosae Sports",
    image: "/images/sponsors/mosae-sports.png",
  },
  {
    name: "Strada B.V.",
    image: "/images/sponsors/strada-bv.png",
  },
  {
    name: "Plus",
    image: "/images/sponsors/plus.png",
  },
  {
    name: "Mosae Sports",
    image: "/images/sponsors/mosae-sports.png",
  }
];
---

<section class="mx-auto max-w-screen-xl mt-8 py-8 px-4">
  <h2 class="text-2xl font-semibold text-gray-900 sm:text-3xl text-center mb-8">
    {t("sponsors.title")}
  </h2>

  <div class="swiper sponsors-swiper">
    <div class="swiper-wrapper">
      {
        sponsors.map((sponsor) => (
          <div class="swiper-slide">
            <img
              src={sponsor.image}
              alt={sponsor.name}
              class="swiper-custom-img"
            />
          </div>
        ))
      }
    </div>
    <div class="swiper-pagination"></div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, EffectCoverflow } from 'swiper/modules';
  import 'swiper/css';

  const swiper =new Swiper('.sponsors-swiper', {
    modules: [Autoplay, EffectCoverflow],
     effect: "coverflow",
    grabCursor: true,
    centeredSlides: true,
    slidesPerView: 1,
    breakpoints: {
      720: {
        slidesPerView: 3,
      },
    },
    loop: true,
    coverflowEffect: {
      rotate: 50,
      stretch: 0,
      depth: 100,
      modifier: 1,
      slideShadows: true,
    },
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
    }
  });
</script>

<style>
  .swiper {
    width: 100%;
    padding-top: 50px;
    padding-bottom: 50px;
  }

  .swiper-slide {
    background-position: center;
    background-size: cover;
    width: 200px;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .swiper-custom-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
</style>
